# ─── Variables d'environnement ──────────────────────────────────────────────
# Copie ce fichier en .env et remplace les valeurs

# CoinGecko API (gratuite, pas de clé requise)
VITE_COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# OpenAI API — OBLIGATOIRE pour la page IA
# Obtiens ta clé sur : https://platform.openai.com/api-keys
# Format : sk-proj-XXXXXXXXXXXXXXXXXXXX
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here
